{
  "expo": {
    "name": "ThinkMate",
    "slug": "thinkmate",
    "owner": "companionai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#08090C",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.patmakesapps.thinkmate",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ThinkMate uses the microphone to record meetings so it can transcribe and summarize them.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.patmakesapps.thinkmate",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#08090C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "ThinkMate uses the microphone to record meetings so it can transcribe and summarize them."
        }
      ],
      "expo-sqlite",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "6e7670e5-73ee-4129-adee-1c46548eff74"
      }
    }
  }
}
